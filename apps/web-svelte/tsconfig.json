{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": false,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": false,
		"target": "ES2022",
		"types": ["svelte", "vite/client"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"$lib/*": ["./src/lib/*"]
		}
	},
	"include": ["src/**/*.d.ts", "src/**/*.ts", "src/**/*.js", "src/**/*.svelte"],
	"exclude": ["dist"]
}
